{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 0,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": ["hyprland/workspaces", "window"],
    "modules-center": [],
    "modules-right": ["pulseaudio", "network", "battery", "clock"],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true,
        "active-only": false,
        "all-outputs": false,
        "show-special": false,
        "persistent-workspaces": {}
    },

    "window": {
        "format": "{}",
        "max-length": 50,
        "separate-outputs": true
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-bluetooth": "{icon} {volume}%",
        "format-bluetooth-muted": "蟀潫",
        "format-muted": "蟀潫",
        "format-icons": {
            "headphone": "蟀媼",
            "hands-free": "蟀嵕",
            "headset": "蟀嵕",
            "phone": "蟀弾",
            "portable": "蟀弾",
            "car": "蟀剫",
            "default": ["蟀暱", "蟀杸", "蟀暰"]
        },
        "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "tooltip-format": "Volume: {volume}%"
    },

    "network": {
        "format-wifi": "蟀え {signalStrength}%",
        "format-ethernet": "蟀垁",
        "format-disconnected": "蟀き",
        "format-alt": "{ifname}: {ipaddr}",
        "interval": 5,
        "tooltip-format": "{ifname}: {ipaddr}"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "蟀倓 {capacity}%",
        "format-plugged": "蟀倓 {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"],
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "tooltip-format": "{timeTo}, {capacity}%"
    },

    "clock": {
        "format": "{:%B %-d  %-I:%M %p}",
        "format-alt": "{:%Y-%m-%d}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months":     "<span color='#ffffff'><b>{}</b></span>",
                "days":       "<span color='#cccccc'>{}</span>",
                "weeks":      "<span color='#888888'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffffff'><b>{}</b></span>",
                "today":      "<span color='#ffffff'><b><u>{}</u></b></span>"
            }
        }
    }
}
